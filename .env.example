# =====================================================================
# DERMA INTEL Pro — Environment variables
# =====================================================================
# Copy this file to .env.local and fill in the actual values.
# .env.local is gitignored and stays on your machine / Vercel only.
# Never commit real keys.
# =====================================================================

# ----- Supabase (project URL + anon key, both public) ---------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----- Supabase service role (server-only, full admin powers) -------
# Used in server actions / route handlers that need to bypass RLS.
# NEVER expose this to the browser. Never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic (server-only) --------------------------------------
# Used by lib/claude.ts. All Claude calls go through server code.
ANTHROPIC_API_KEY=

# ----- Admin panel allowlist (server-only) --------------------------
# Comma-separated list of médico emails que pueden ver /mirai-admin
# (panel de telemetría de costos por médico). Si está vacío, el panel
# devuelve 404 para todos (incluida la médica). Fer y nadie más.
# NUNCA prefijar con NEXT_PUBLIC_ — debe quedar server-side.
MIRAI_ADMIN_EMAILS=

# ----- Transcripción de voz / dictado (server-only) -----------------
# Whisper hospedado en Groq (whisper-large-v3) para el dictado tipo
# Wispr Flow en /api/ia/transcribir. Crear cuenta gratis en
# console.groq.com → API Keys. Si está vacío, el dictado por voz
# devuelve un error claro y la médica puede escribir a mano.
# (Para usar OpenAI Whisper en su lugar, cambiar la URL/modelo en
#  app/api/ia/transcribir/route.ts y poner aquí la key de OpenAI.)
GROQ_API_KEY=
